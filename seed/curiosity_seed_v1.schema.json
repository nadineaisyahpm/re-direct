{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://redirect.app/schema/curiosity_seed_v1.json",
  "title": "re:direct curiosity seed",
  "description": "Bundled curated content for re:direct. Generated by AI-bootstrap, human-reviewed, then shipped in the app bundle. Loaded once on first launch into SwiftData; subsequent launches diff by seed_version.",
  "type": "object",
  "required": ["seed_version", "generated_at", "locale", "topics", "reminder_themes", "redirect_methods"],
  "additionalProperties": false,
  "properties": {
    "seed_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonic version. Increment when the curated corpus changes."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "locale": {
      "type": "string",
      "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
      "description": "BCP-47. Each seed file is single-locale; multi-locale ships as multiple files."
    },
    "topics": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Topic" }
    },
    "trails": {
      "type": "array",
      "items": { "$ref": "#/$defs/Trail" }
    },
    "reminder_themes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ReminderTheme" }
    },
    "redirect_methods": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/RedirectMethod" }
    }
  },
  "$defs": {
    "Topic": {
      "type": "object",
      "required": ["slug", "title", "summary", "cover_asset_name", "accent_color_hex", "prompts"],
      "additionalProperties": false,
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,63}$",
          "description": "Stable identifier. Used by AI proxy responses to link back to a seeded topic."
        },
        "title": { "type": "string", "minLength": 1, "maxLength": 80 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 240 },
        "cover_asset_name": {
          "type": "string",
          "description": "Asset Catalog name. Asset must exist in the iOS bundle."
        },
        "accent_color_hex": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "prompts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Prompt" }
        }
      }
    },
    "Prompt": {
      "type": "object",
      "required": ["slug", "body", "source", "estimated_minutes"],
      "additionalProperties": false,
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,63}$",
          "description": "Unique within the topic. Used for trail steps and review tracking."
        },
        "body": { "type": "string", "minLength": 1, "maxLength": 600 },
        "source": {
          "type": "string",
          "enum": ["seed", "ai-bootstrap"],
          "description": "Provenance. Runtime AI-generated prompts use 'ai-runtime' and do not appear in seed files."
        },
        "tier": {
          "type": "string",
          "enum": ["free"],
          "default": "free"
        },
        "estimated_minutes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 240
        },
        "review": {
          "$ref": "#/$defs/ReviewMeta"
        }
      }
    },
    "Trail": {
      "type": "object",
      "required": ["slug", "topic_slug", "title", "summary", "steps"],
      "additionalProperties": false,
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
        },
        "topic_slug": {
          "type": "string",
          "description": "Must match a topic.slug in this file."
        },
        "title": { "type": "string", "minLength": 1, "maxLength": 80 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 240 },
        "steps": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/TrailStep" }
        }
      }
    },
    "TrailStep": {
      "type": "object",
      "required": ["step_order", "prompt_slug", "estimated_minutes"],
      "additionalProperties": false,
      "properties": {
        "step_order": {
          "type": "integer",
          "minimum": 1
        },
        "prompt_slug": {
          "type": "string",
          "description": "References a Prompt.slug within the trail's parent topic."
        },
        "estimated_minutes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 240
        }
      }
    },
    "ReminderTheme": {
      "type": "object",
      "required": ["slug", "display_name", "asset_name"],
      "additionalProperties": false,
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
        },
        "display_name": { "type": "string", "minLength": 1, "maxLength": 60 },
        "asset_name": { "type": "string" }
      }
    },
    "RedirectMethod": {
      "type": "object",
      "required": ["slug", "display_name", "summary"],
      "additionalProperties": false,
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
        },
        "display_name": { "type": "string", "minLength": 1, "maxLength": 60 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 240 }
      }
    },
    "ReviewMeta": {
      "type": "object",
      "description": "Optional human-review metadata. Stripped from the bundled file at build time.",
      "additionalProperties": false,
      "properties": {
        "reviewed_by": { "type": "string" },
        "reviewed_at": { "type": "string", "format": "date-time" },
        "ai_source_model": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  }
}
